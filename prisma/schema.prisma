datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  Avis      Avis[]
  Favori    Favori[]
}

model Lieu {
  id        Int        @id @default(autoincrement())
  nom       String
  description String?
  adresse   String?
  createdAt DateTime   @default(now())
  Photos    Photo[]
  Avis      Avis[]
  Favoris   Favori[]
  Categories LieuCategorie[]
}

model Categorie {
  id    Int             @id @default(autoincrement())
  label String          @unique
  Lieux LieuCategorie[]
}

model LieuCategorie {
  lieuId      Int
  categorieId Int
  Lieu        Lieu      @relation(fields: [lieuId], references: [id])
  Categorie   Categorie @relation(fields: [categorieId], references: [id])
  @@id([lieuId, categorieId])
}

model Photo {
  id     Int   @id @default(autoincrement())
  url    String
  alt    String?
  lieuId Int
  Lieu   Lieu  @relation(fields: [lieuId], references: [id])
}

model Avis {
  id        Int      @id @default(autoincrement())
  contenu   String
  note      Int
  userId    Int
  lieuId    Int
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id])
  Lieu      Lieu     @relation(fields: [lieuId], references: [id])
}

model Favori {
  userId Int
  lieuId Int
  User   User @relation(fields: [userId], references: [id])
  Lieu   Lieu @relation(fields: [lieuId], references: [id])
  @@id([userId, lieuId])
}
